{
  "name": "tianyanvision",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "prepare": "husky",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts,.vue --max-warnings 0",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "screenshot": "node scripts/capture-dashboard.mjs",
    "screenshot:dashboard": "node scripts/capture-dashboard.mjs"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "dayjs": "^1.11.13",
    "echarts": "^5.5.1",
    "pinia": "^2.2.6",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/eslint-config-prettier": "^10.1.0",
    "@vue/eslint-config-typescript": "^14.4.0",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-plugin-vue": "^9.32.0",
    "happy-dom": "^16.8.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "playwright": "^1.61.1",
    "postcss": "^8.5.1",
    "prettier": "^3.4.2",
    "sass": "^1.83.4",
    "stylelint": "^16.13.2",
    "stylelint-config-standard": "^36.0.1",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vitest": "^2.1.8",
    "vue-tsc": "^2.1.10"
  },
  "lint-staged": {
    "*.{ts,vue,js,json,md,css,scss}": [
      "prettier --write"
    ]
  }
}
